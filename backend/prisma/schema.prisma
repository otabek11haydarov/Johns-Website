// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

model User {
  id        String   @id @default(uuid())
  username  String
  email     String   @unique
  password  String
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now())
}

model Book {
  id        Int      @id @default(autoincrement())
  title     String
  author    String
  level     String
  pdf       String
  image     String   @default("default-book.png")
  createdAt DateTime @default(now())
}

model Group {
  id             String   @id @default(uuid())
  level          String
  label          String
  title          String
  description    String?
  studentsCount  Int      @default(0)
  mentor         String?
  lessonsPerWeek Int      @default(3)
  room           String?
  status         String   @default("Active")
}

model Lesson {
  id          String   @id @default(uuid())
  title       String
  groupLevel  String
  description String?
  tasks       Task[]
}

model Task {
  id          String  @id @default(uuid())
  description String
  lessonId    String?
  lesson      Lesson? @relation(fields: [lessonId], references: [id])
}

model Activity {
  id    String @id @default(uuid())
  rank  Int
  name  String
  email String
  group String
  score Int
}
