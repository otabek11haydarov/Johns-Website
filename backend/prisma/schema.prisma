// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

model User {
  id             String   @id @default(uuid())
  username       String   @unique
  email          String   @unique
  password       String
  role           Role     @default(STUDENT)
  status         String   @default("Active")
  createdAt      DateTime @default(now())

  // Relations
  groupId        String?
  group          Group?   @relation("GroupStudents", fields: [groupId], references: [id])
  mentoredGroups Group[]  @relation("GroupMentor")
}

model Book {
  id        Int      @id @default(autoincrement())
  title     String
  author    String
  level     String
  pdf       String
  image     String   @default("default-book.png")
  createdAt DateTime @default(now())
}

model Group {
  id             String   @id @default(uuid())
  level          String
  label          String
  title          String
  description    String?
  studentsCount  Int      @default(0)
  mentorId       String?
  mentor         User?    @relation("GroupMentor", fields: [mentorId], references: [id])
  lessonsPerWeek Int      @default(3)
  room           String?
  status         String   @default("Active")

  // Relations
  students       User[]   @relation("GroupStudents")
}

model Lesson {
  id          String   @id @default(uuid())
  title       String
  groupLevel  String
  description String?
  tasks       Task[]
}

model Task {
  id          String  @id @default(uuid())
  description String
  lessonId    String?
  lesson      Lesson? @relation(fields: [lessonId], references: [id])
}

model Activity {
  id    String @id @default(uuid())
  rank  Int
  name  String
  email String
  group String
  score Int
}
